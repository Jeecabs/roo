#!/usr/bin/env node

const { spawn } = require("child_process");
const fs = require("fs");
const os = require("os");
const path = require("path");

const ROO_BASE = path.join("/tmp", "roo");
const ROO_DIR = path.join(ROO_BASE, process.cwd());

const MAX_LOG_BYTES = 10 * 1024 * 1024; // 10 MB
const MAX_AGE_MS = 7 * 24 * 60 * 60 * 1000; // 7 days

const stripAnsi = (str) =>
  str.replace(
    /[\u001b\u009b]\[[0-9;]*[a-zA-Z]|\u001b\].*?(?:\u0007|\u001b\\)/g,
    ""
  );

// ── Housekeeping ──

function housekeep() {
  if (!fs.existsSync(ROO_BASE)) return;
  const now = Date.now();
  pruneOldDirs(ROO_BASE, now);
}

function pruneOldDirs(dir, now) {
  let entries;
  try { entries = fs.readdirSync(dir, { withFileTypes: true }); } catch { return; }
  for (const ent of entries) {
    const full = path.join(dir, ent.name);
    if (!ent.isDirectory()) continue;
    // If this dir has a "cmd" file, it's a process dir — check age
    const cmd = path.join(full, "cmd");
    if (fs.existsSync(cmd)) {
      try {
        const mtime = fs.statSync(cmd).mtimeMs;
        if (now - mtime > MAX_AGE_MS) {
          // Don't remove if still running
          const pf = path.join(full, "pid");
          if (fs.existsSync(pf)) {
            const pid = parseInt(fs.readFileSync(pf, "utf8").trim());
            try { process.kill(pid, 0); continue; } catch {}
          }
          fs.rmSync(full, { recursive: true, force: true });
        }
      } catch {}
    } else {
      // Recurse into intermediate path directories
      pruneOldDirs(full, now);
      // Remove empty intermediate dirs
      try {
        if (fs.readdirSync(full).length === 0) fs.rmdirSync(full);
      } catch {}
    }
  }
}

function truncateLog(logPath) {
  try {
    const stat = fs.statSync(logPath);
    if (stat.size <= MAX_LOG_BYTES) return;
    const buf = Buffer.alloc(MAX_LOG_BYTES / 2);
    const fd = fs.openSync(logPath, "r");
    fs.readSync(fd, buf, 0, buf.length, stat.size - buf.length);
    fs.closeSync(fd);
    const text = buf.toString();
    const firstNewline = text.indexOf("\n");
    const kept = firstNewline >= 0 ? text.slice(firstNewline + 1) : text;
    fs.writeFileSync(logPath, `[roo] log truncated (exceeded ${MAX_LOG_BYTES / 1024 / 1024}MB)\n` + kept);
  } catch {}
}

housekeep();

// ── Naming ──

function deriveName(cmdArgs) {
  const full = cmdArgs.join(" ");
  // npm run <x> / yarn <x> / pnpm <x> → use the script name
  const npmMatch = full.match(/(?:npm run|yarn|pnpm(?:\s+run)?)\s+(\S+)/);
  if (npmMatch) return sanitize(npmMatch[1]);
  // node/python/ruby <file> → use filename without extension
  const fileMatch = full.match(/(?:node|python|ruby|bun|deno|go run)\s+(\S+)/);
  if (fileMatch) return sanitize(path.basename(fileMatch[1], path.extname(fileMatch[1])));
  // fallback: first arg that looks like a command (not a flag or single char)
  for (const w of cmdArgs) {
    if (!w.startsWith("-") && w.length > 1 && !/^[A-Z_]+=/.test(w)) {
      return sanitize(path.basename(w, path.extname(w)));
    }
  }
  return `proc-${Date.now().toString(36).slice(-4)}`;
}

function sanitize(name) {
  return name.replace(/[^a-zA-Z0-9_-]/g, "-").toLowerCase().slice(0, 30);
}

// ── Process helpers ──

function procDir(name) { return path.join(ROO_DIR, name); }
function logFile(name) { return path.join(procDir(name), "output.log"); }
function pidFile(name) { return path.join(procDir(name), "pid"); }
function cmdFile(name) { return path.join(procDir(name), "cmd"); }
function startedFile(name) { return path.join(procDir(name), "started"); }

function ensureProc(name) {
  const d = procDir(name);
  if (!fs.existsSync(d)) fs.mkdirSync(d, { recursive: true });
}

function pidAlive(pid) {
  try { process.kill(pid, 0); return true; } catch { return false; }
}

function getPid(name) {
  const f = pidFile(name);
  if (!fs.existsSync(f)) return null;
  const pid = parseInt(fs.readFileSync(f, "utf8").trim());
  return pidAlive(pid) ? pid : null;
}

function getCmd(name) {
  const f = cmdFile(name);
  return fs.existsSync(f) ? fs.readFileSync(f, "utf8").trim() : "?";
}

function getStarted(name) {
  const f = startedFile(name);
  return fs.existsSync(f) ? fs.readFileSync(f, "utf8").trim() : "?";
}

function allProcs() {
  if (!fs.existsSync(ROO_DIR)) return [];
  return fs.readdirSync(ROO_DIR).filter((d) => {
    const full = path.join(ROO_DIR, d);
    return fs.statSync(full).isDirectory() && fs.existsSync(path.join(full, "cmd"));
  });
}

// Find a unique name if collision
function uniqueName(base) {
  if (!fs.existsSync(procDir(base)) || !getPid(base)) return base;
  for (let i = 2; i <= 99; i++) {
    const n = `${base}-${i}`;
    if (!fs.existsSync(procDir(n)) || !getPid(n)) return n;
  }
  return `${base}-${Date.now().toString(36).slice(-4)}`;
}

// ── Parse --name flag from args, return { name, rest } ──

function parseNameFlag(args) {
  for (let i = 0; i < args.length; i++) {
    if ((args[i] === "--name" || args[i] === "-n") && args[i + 1]) {
      const name = sanitize(args[i + 1]);
      const rest = [...args.slice(0, i), ...args.slice(i + 2)];
      return { name, rest };
    }
  }
  return { name: null, rest: args };
}

// ── TUI helpers ──

function formatUptime(startTime) {
  const s = Math.floor((Date.now() - startTime) / 1000);
  if (s < 60) return `up ${s}s`;
  if (s < 3600) return `up ${Math.floor(s / 60)}m${String(s % 60).padStart(2, "0")}s`;
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  return `up ${h}h${String(m).padStart(2, "0")}m`;
}

function drawBar(text) {
  const rows = process.stdout.rows || 24;
  const cols = process.stdout.columns || 80;
  process.stdout.write("\x1b7");
  process.stdout.write(`\x1b[${rows};1H`);
  process.stdout.write("\x1b[2K");
  process.stdout.write(`\x1b[7m ${text.padEnd(cols - 1)}\x1b[0m`);
  process.stdout.write("\x1b8");
}

function setupScrollRegion() {
  const rows = process.stdout.rows || 24;
  process.stdout.write(`\x1b[1;${rows - 1}r`);
  process.stdout.write(`\x1b[${rows - 1};1H`);
}

function resetTerminal() {
  const rows = process.stdout.rows || 24;
  process.stdout.write(`\x1b[1;${rows}r`);
  process.stdout.write(`\x1b[${rows};1H\x1b[2K`);
}

// ── Resolve name: explicit arg, or pick the only running one, or error ──

function resolveName(explicit) {
  if (explicit && !["--help", "-h"].includes(explicit)) return explicit;
  const procs = allProcs();
  const running = procs.filter((n) => getPid(n));
  if (running.length === 1) return running[0];
  if (running.length === 0) {
    // pick the most recent stopped one for logs
    if (procs.length === 1) return procs[0];
    if (procs.length === 0) return null;
    console.error("multiple processes found. specify a name:");
    procs.forEach((n) => console.error(`  ${n}`));
    process.exit(1);
  }
  console.error("multiple running processes. specify a name:");
  running.forEach((n) => console.error(`  ${n}  (pid ${getPid(n)})`));
  process.exit(1);
}

// ── Commands ──

const sub = process.argv[2];

if (!sub || sub === "--help" || sub === "-h") {
  console.log(`roo - lightweight process wrapper with TUI

  roo <cmd...>                  run with TUI, auto-named
  roo start <cmd...>            run in background, auto-named
  roo start --name api <cmd>    run in background with explicit name
  roo status [--json]            list all processes (--json for machine-readable)
  roo logs [name] [n]           last n lines (default 40)
  roo attach [name]             attach TUI to running process
  roo stop [name]               stop a process (or all with --all)
  roo clean                     remove stopped process dirs

TUI keys:
  q/Ctrl+C  kill process and exit (default)
  d         detach (leave process running in background)
  p         pause/unpause output

Names are auto-derived from commands:
  npm run dev → dev    node server.js → server
  npm run build → build    python app.py → app

Multiple processes per directory:
  roo start npm run dev        → .roo/dev/output.log
  roo start npm run build      → .roo/build/output.log
  roo start --name api npm run start → .roo/api/output.log`);
  process.exit(0);
}

// ── status ──
if (sub === "status") {
  const jsonFlag = process.argv.includes("--json");
  const procs = allProcs();
  if (jsonFlag) {
    const result = procs.map((name) => {
      const pid = getPid(name);
      const started = getStarted(name);
      const startMs = started !== "?" ? new Date(started).getTime() : null;
      return {
        name,
        status: pid ? "running" : "stopped",
        pid: pid || null,
        started,
        cmd: getCmd(name),
        log: logFile(name),
        uptime: pid && startMs ? formatUptime(startMs) : null,
      };
    });
    console.log(JSON.stringify(result, null, 2));
    process.exit(0);
  }
  if (procs.length === 0) {
    console.log("no processes");
    process.exit(0);
  }
  for (const name of procs) {
    const pid = getPid(name);
    const cmd = getCmd(name);
    const started = getStarted(name);
    const status = pid ? "running" : "stopped";
    const log = logFile(name);
    console.log(`process  name=${name}  status=${status}  pid=${pid || "—"}  started=${started}  cmd="${cmd}"  log=${log}`);
  }
  process.exit(0);
}

// ── stop ──
if (sub === "stop") {
  const arg = process.argv[3];

  if (arg === "--all") {
    const procs = allProcs();
    let stopped = 0;
    for (const name of procs) {
      const pid = getPid(name);
      if (pid) {
        process.kill(pid, "SIGTERM");
        console.log(`stopped  ${name}  pid=${pid}`);
        stopped++;
      }
    }
    if (stopped === 0) console.log("nothing running");
    setTimeout(() => {
      for (const name of procs) {
        try { fs.unlinkSync(pidFile(name)); } catch {}
      }
      process.exit(0);
    }, 1500);
    return;
  }

  const name = resolveName(arg);
  if (!name) { console.log("nothing running"); process.exit(0); }
  const pid = getPid(name);
  if (!pid) { console.log(`${name}: not running`); process.exit(0); }
  process.kill(pid, "SIGTERM");
  console.log(`stopped  ${name}  pid=${pid}`);
  setTimeout(() => {
    if (getPid(name)) {
      process.kill(pid, "SIGKILL");
      console.log(`force killed ${name}`);
    }
    try { fs.unlinkSync(pidFile(name)); } catch {}
    process.exit(0);
  }, 1500);
}

// ── clean ──
else if (sub === "clean") {
  const procs = allProcs();
  let cleaned = 0;
  for (const name of procs) {
    if (!getPid(name)) {
      fs.rmSync(procDir(name), { recursive: true, force: true });
      console.log(`removed  ${name}`);
      cleaned++;
    }
  }
  if (cleaned === 0) console.log("nothing to clean");
  // Remove ROO_DIR if empty
  if (fs.existsSync(ROO_DIR) && fs.readdirSync(ROO_DIR).length === 0) {
    fs.rmSync(ROO_DIR, { recursive: true, force: true });
  }
  process.exit(0);
}

// ── logs ──
else if (sub === "logs") {
  // roo logs [name] [n]  — name is optional if only one proc
  let name = null;
  let n = 40;
  const args = process.argv.slice(3);
  for (const a of args) {
    if (/^\d+$/.test(a)) n = parseInt(a);
    else name = a;
  }
  name = resolveName(name);
  if (!name) { console.log("no processes"); process.exit(0); }
  const log = logFile(name);
  if (!fs.existsSync(log)) { console.log(`${name}: no logs yet`); process.exit(0); }
  const lines = fs.readFileSync(log, "utf8").split("\n");
  console.log(lines.slice(Math.max(0, lines.length - n)).join("\n"));
  process.exit(0);
}

// ── attach ──
else if (sub === "attach") {
  const name = resolveName(process.argv[3]);
  if (!name) { console.log("nothing to attach to"); process.exit(0); }
  const pid = getPid(name);
  if (!pid) { console.log(`${name}: not running`); process.exit(0); }
  const log = logFile(name);
  if (!fs.existsSync(log)) { console.log("no log file"); process.exit(1); }

  setupScrollRegion();

  const existing = fs.readFileSync(log, "utf8");
  const rows = process.stdout.rows || 24;
  const recentLines = existing.split("\n").slice(-(rows - 5));
  for (const line of recentLines) process.stdout.write(line + "\n");

  const attachStartTime = new Date(getStarted(name)).getTime();
  let attachPaused = false;
  let attachPauseBuf = [];

  function attachBarText() {
    const pause = attachPaused ? "  [PAUSED]" : "";
    return `${name}  │  ${getCmd(name)}  │  pid ${pid}  │  ${formatUptime(attachStartTime)}${pause}  │  q/Ctrl+C: quit+kill  d: detach  p: pause`;
  }
  drawBar(attachBarText());

  let filePos = fs.statSync(log).size;
  const poll = setInterval(() => {
    try {
      const stat = fs.statSync(log);
      if (stat.size > filePos) {
        const fd = fs.openSync(log, "r");
        const buf = Buffer.alloc(stat.size - filePos);
        fs.readSync(fd, buf, 0, buf.length, filePos);
        fs.closeSync(fd);
        filePos = stat.size;
        const data = buf.toString();
        if (attachPaused) {
          attachPauseBuf.push(data);
        } else {
          process.stdout.write(data);
        }
        drawBar(attachBarText());
      }
    } catch {}
  }, 100);

  const barTick = setInterval(() => drawBar(attachBarText()), 1000);

  const statusPoll = setInterval(() => {
    if (!getPid(name)) {
      clearInterval(poll);
      clearInterval(statusPoll);
      clearInterval(barTick);
      resetTerminal();
      if (process.stdin.isTTY) process.stdin.setRawMode(false);
      console.log(`\n[roo:${name}] process exited`);
      process.exit(0);
    }
  }, 1000);

  if (process.stdin.isTTY) {
    process.stdin.setRawMode(true);
    process.stdin.resume();
    process.stdin.on("data", (key) => {
      if (key[0] === 0x71 || key[0] === 0x03) {
        // q or Ctrl+C = kill + exit
        clearInterval(poll);
        clearInterval(statusPoll);
        clearInterval(barTick);
        resetTerminal();
        process.stdin.setRawMode(false);
        try { process.kill(-pid, "SIGTERM"); } catch {}
        try { process.kill(pid, "SIGTERM"); } catch {}
        try { fs.unlinkSync(pidFile(name)); } catch {}
        // force kill after 2s if still alive
        setTimeout(() => {
          try { process.kill(-pid, "SIGKILL"); } catch {}
          try { process.kill(pid, "SIGKILL"); } catch {}
        }, 2000);
        console.log(`\n[roo:${name}] killed`);
        process.exit(0);
      }
      if (key[0] === 0x64) {
        // d = detach (leave running)
        clearInterval(poll);
        clearInterval(statusPoll);
        clearInterval(barTick);
        resetTerminal();
        process.stdin.setRawMode(false);
        console.log(`\n[roo:${name}] detached. still running.`);
        process.exit(0);
      }
      if (key[0] === 0x70) {
        // p = toggle pause
        attachPaused = !attachPaused;
        if (!attachPaused && attachPauseBuf.length > 0) {
          process.stdout.write(attachPauseBuf.join(""));
          attachPauseBuf = [];
        }
        drawBar(attachBarText());
      }
    });
  }

  process.stdout.on("resize", () => {
    setupScrollRegion();
    drawBar(attachBarText());
  });
}

// ── start (background) ──
else if (sub === "start") {
  const { name: explicitName, rest } = parseNameFlag(process.argv.slice(3));
  if (rest.length === 0) {
    console.error("usage: roo start [--name <n>] <command...>");
    process.exit(1);
  }
  const baseName = explicitName || deriveName(rest);
  const name = uniqueName(baseName);
  ensureProc(name);

  const log = logFile(name);
  const logFd = fs.openSync(log, "w");
  const now = new Date().toISOString();
  const header = `[roo:${name}] started: ${rest.join(" ")}\n[roo:${name}] time: ${now}\n[roo:${name}] ${"—".repeat(60)}\n`;
  fs.writeSync(logFd, header);

  const child = spawn(rest[0], rest.slice(1), {
    stdio: ["ignore", logFd, logFd],
    shell: true,
    detached: true,
    env: { ...process.env, FORCE_COLOR: "0" },
  });

  fs.writeFileSync(pidFile(name), String(child.pid));
  fs.writeFileSync(cmdFile(name), rest.join(" "));
  fs.writeFileSync(startedFile(name), now);
  child.unref();

  console.log(`started  name=${name}  pid=${child.pid}`);
  console.log(`logs     ${log}`);
  console.log(`\n  roo attach ${name}`);
  console.log(`  roo logs ${name}`);
  console.log(`  roo stop ${name}`);

  child.on("close", (code) => {
    fs.appendFileSync(log, `\n[roo:${name}] exited with code ${code}\n`);
    truncateLog(log);
    try { fs.unlinkSync(pidFile(name)); } catch {}
  });

  setTimeout(() => process.exit(0), 300);
}

// ── default: foreground TUI ──
else {
  const { name: explicitName, rest } = parseNameFlag(process.argv.slice(2));
  const cmd = rest;
  const baseName = explicitName || deriveName(cmd);
  const name = uniqueName(baseName);
  ensureProc(name);

  const log = logFile(name);
  const logStream = fs.createWriteStream(log, { flags: "w" });
  const now = new Date().toISOString();
  let logBytes = 0;
  const writeLog = (str) => {
    if (logBytes > MAX_LOG_BYTES) return;
    logStream.write(str);
    logBytes += Buffer.byteLength(str);
    if (logBytes > MAX_LOG_BYTES) {
      logStream.end();
      truncateLog(log);
      // Reopen in append mode for any final messages
    }
  };
  writeLog(`[roo:${name}] started: ${cmd.join(" ")}\n`);
  writeLog(`[roo:${name}] time: ${now}\n`);
  writeLog(`[roo:${name}] ${"—".repeat(60)}\n`);

  const child = spawn(cmd[0], cmd.slice(1), {
    stdio: ["ignore", "pipe", "pipe"],
    shell: true,
    detached: true,
    env: { ...process.env, FORCE_COLOR: "1" },
  });

  fs.writeFileSync(pidFile(name), String(child.pid));
  fs.writeFileSync(cmdFile(name), cmd.join(" "));
  fs.writeFileSync(startedFile(name), now);

  setupScrollRegion();

  const fgStartTime = Date.now();
  let fgPaused = false;
  let fgPauseBuf = [];

  function fgBarText() {
    const pause = fgPaused ? "  [PAUSED]" : "";
    return `${name}  │  ${cmd.join(" ")}  │  pid ${child.pid}  │  ${formatUptime(fgStartTime)}${pause}  │  q/Ctrl+C: quit+kill  d: detach  p: pause`;
  }
  drawBar(fgBarText());

  const fgBarTick = setInterval(() => drawBar(fgBarText()), 1000);

  child.stdout.on("data", (data) => {
    if (fgPaused) {
      fgPauseBuf.push(data);
    } else {
      process.stdout.write(data);
    }
    writeLog(stripAnsi(data.toString()));
    drawBar(fgBarText());
  });

  child.stderr.on("data", (data) => {
    if (fgPaused) {
      fgPauseBuf.push(Buffer.from(`\x1b[2;31m${data}\x1b[0m`));
    } else {
      process.stdout.write(`\x1b[2;31m${data}\x1b[0m`);
    }
    writeLog(stripAnsi(data.toString()));
    drawBar(fgBarText());
  });

  if (process.stdin.isTTY) {
    process.stdin.setRawMode(true);
    process.stdin.resume();
    let killing = false;
    process.stdin.on("data", (key) => {
      if (key[0] === 0x71 || key[0] === 0x03) {
        // q or Ctrl+C = kill + exit
        clearInterval(fgBarTick);
        if (!killing) {
          killing = true;
          try { process.kill(-child.pid, "SIGTERM"); } catch {}
          child.kill("SIGTERM");
          // force kill + exit if SIGTERM doesn't work after 2s
          setTimeout(() => {
            try { process.kill(-child.pid, "SIGKILL"); } catch {}
            try { child.kill("SIGKILL"); } catch {}
            resetTerminal();
            process.stdin.setRawMode(false);
            try { fs.unlinkSync(pidFile(name)); } catch {}
            logStream.end();
            console.log(`\n[roo:${name}] force killed`);
            process.exit(1);
          }, 2000);
        } else {
          // second press = force kill immediately
          try { process.kill(-child.pid, "SIGKILL"); } catch {}
          try { child.kill("SIGKILL"); } catch {}
          resetTerminal();
          process.stdin.setRawMode(false);
          try { fs.unlinkSync(pidFile(name)); } catch {}
          logStream.end();
          console.log(`\n[roo:${name}] force killed`);
          process.exit(1);
        }
      }
      if (key[0] === 0x64) {
        // d = detach (leave running)
        clearInterval(fgBarTick);
        resetTerminal();
        process.stdin.setRawMode(false);
        child.unref();
        logStream.end();
        console.log(`\n[roo:${name}] detached. still running.`);
        console.log(`  roo attach ${name}`);
        console.log(`  roo logs ${name}`);
        console.log(`  roo stop ${name}`);
        process.exit(0);
      }
      if (key[0] === 0x70) {
        // p = toggle pause
        fgPaused = !fgPaused;
        if (!fgPaused && fgPauseBuf.length > 0) {
          for (const chunk of fgPauseBuf) process.stdout.write(chunk);
          fgPauseBuf = [];
        }
        drawBar(fgBarText());
      }
    });
  }

  child.on("close", (code) => {
    clearInterval(fgBarTick);
    resetTerminal();
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
    logStream.write(`\n[roo:${name}] exited with code ${code}\n`);
    try { fs.unlinkSync(pidFile(name)); } catch {}
    logStream.end();
    console.log(`\n[roo:${name}] exited with code ${code}`);
    process.exit(code ?? 1);
  });

  child.on("error", (err) => {
    clearInterval(fgBarTick);
    resetTerminal();
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
    console.error(`[roo:${name}] failed: ${err.message}`);
    logStream.end();
    process.exit(1);
  });

  process.stdout.on("resize", () => {
    setupScrollRegion();
    drawBar(fgBarText());
  });
}
