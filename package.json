{
  "name": "whiskd",
  "version": "3.0.0",
  "description": "Lightweight process wrapper with a TUI status bar for agents and humans.",
  "bin": {
    "whiskd": "./whiskd"
  },
  "scripts": {
    "check": "node --check whiskd",
    "smoke": "node --check whiskd && node whiskd status --json"
  },
  "keywords": [
    "agents",
    "process-manager",
    "tui",
    "logs",
    "dev-server"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
